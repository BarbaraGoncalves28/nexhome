generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model favorites {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String     @db.Uuid
  property_id String     @db.Uuid
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  properties  properties @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_favorite_property")
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_favorite_user")

  @@unique([user_id, property_id], map: "unique_favorite")
}

model leads {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @db.VarChar(255)
  email       String      @db.VarChar(255)
  phone       String      @db.VarChar(255)
  message     String?
  status      lead_status @default(NEW)
  property_id String      @db.Uuid
  created_at  DateTime    @default(now()) @db.Timestamp(6)
  properties  properties  @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_property")
}

model properties {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title           String            @db.VarChar(200)
  description     String
  price           Decimal           @db.Decimal(12, 2)
  area            Int
  bedrooms        Int
  bathrooms       Int
  garage_spots    Int
  city            String            @db.VarChar(100)
  district        String            @db.VarChar(100)
  address         String
  property_type   String            @db.VarChar(20)
  status          String            @default("AVAILABLE") @db.VarChar(20)
  owner_id        String            @db.Uuid
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  updated_at      DateTime?         @default(now()) @db.Timestamp(6)
  latitude        Decimal?          @db.Decimal(10, 8)
  longitude       Decimal?          @db.Decimal(11, 8)
  favorites       favorites[]
  leads           leads[]
  users           users             @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_owner")
  property_images property_images[]
  visits          visits[]
}

model property_images {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  image_url   String
  property_id String     @db.Uuid
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  properties  properties @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_property")
}

model users {
  id         String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String       @db.VarChar(120)
  email      String       @unique @db.VarChar(150)
  password   String
  role       String       @default("CLIENT") @db.VarChar(20)
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  updated_at DateTime?    @default(now()) @db.Timestamp(6)
  favorites  favorites[]
  properties properties[]
  visits     visits[]
}

model visits {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  visit_date  DateTime   @db.Timestamp(6)
  notes       String?
  status      String     @default("PENDING") @db.VarChar(20)
  user_id     String     @db.Uuid
  property_id String     @db.Uuid
  created_at  DateTime?  @default(now()) @db.Timestamp(6)
  properties  properties @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_visit_property")
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_visit_user")
}

enum PropertyType {
  HOUSE
  APARTMENT
  COMMERCIAL
  LAND
}

enum lead_status {
  NEW
  CONTACTED
  NEGOTIATING
  CLOSED
}
